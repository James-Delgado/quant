# Secrets
.env

# Data lake — never commit data; it is reproducible from the raw layer / APIs.
# Use `data/*` (not `data/`) so the negations below can re-include specific
# files — git cannot re-include a child of a fully-excluded directory.
data/*
!data/.gitkeep
# Exception: the trial-count ledger is a tracked code artifact (METHODOLOGY.md
# §12, ROADMAP §8.6). It must be committed so the append-only-across-commits
# CI check (tests/test_ledger.py) can read its git history.
!data/ledger.yaml

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Prefect
.prefect/

# Notebooks
.ipynb_checkpoints/

# macOS Finder metadata (per-folder view settings; never project content)
.DS_Store
**/.DS_Store

# Console static export (E1) — generated by `python -m quant.console export`,
# reproducible from artifacts; the directory is kept (.gitkeep) but its JSON
# payloads are never committed (they can go stale vs the artifacts).
src/quant/console/export/*.json
src/quant/console/export/**/*.json
.gstack/
