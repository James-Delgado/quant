# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# All four providers have free tiers — no payment required for Phase 0.

# Alpaca — free account at https://alpaca.markets (data works on unfunded accounts)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Tiingo — free token at https://www.tiingo.com
TIINGO_API_KEY=

# FRED — free key at https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
